# ============================================
# PRISM — Environment Variables Template
# ============================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Application ──
ENVIRONMENT=development
DEBUG=true

# ── Database ──
DATABASE_URL=postgresql+asyncpg://prism:prism@localhost:5432/prism

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── GitHub App ──
# Create a GitHub App at: https://github.com/settings/apps/new
# Required permissions: Pull Requests (R/W), Checks (R/W), Contents (Read)
# Subscribe to events: Pull request
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=     # Path to your .pem file, or paste the full key inline
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=      # The secret you set when creating the GitHub App

# ── AI Provider (set ONE — PRISM auto-detects which you configured) ──
# If none is set, PRISM runs in deterministic-only mode (no AI, still works!)

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini: https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=

# Mistral: https://console.mistral.ai/api-keys (free tier available)
MISTRAL_API_KEY=

# Ollama (local, completely free): https://ollama.ai
# Set this to your Ollama server URL (e.g. http://localhost:11434)
OLLAMA_URL=

# Custom OpenAI-compatible API (e.g. Azure OpenAI, Together AI, LM Studio)
CUSTOM_LLM_URL=
CUSTOM_LLM_KEY=
CUSTOM_LLM_MODEL=

# ── Auth ──
JWT_SECRET_KEY=dev-secret-change-in-production
